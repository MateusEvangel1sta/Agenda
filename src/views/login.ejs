<%- include('includes/head') %>
<%- include('includes/nav') %>

<div class="container">
  <div class="row">
    <div class="col-lg-2"></div>

    <div class="col-lg-8 my-3">
      <h1 class="text-center">Regristre-se ou Entre</h1>
      <p class="text-center lead">
        Faça login ou crie a sua conta
      </p>
      
      <div class="row">
        <div class="col-lg">
          <h4>Faça seu cadastro</h4>
          <p>
            Se você ainda não tem conta, preencha o formulário abaixo:
          </p>

          <form action="/login/register" method="POST">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <div class="form-group">
              <label for="exampleInputEmail1">Seu e-mail</label>
              <input type="email" class="form-control" name="email" aria-describedby="emailHelp" placeholder="Digite o seu e-mail">
              <small id="emailHelp" class="form-text text-muted">Nunca compartilhamos o seu e-mail.</small>
            </div>
            <div class="form-group">
              <label for="exampleInputPassword1">Password</label>
              <input type="password" class="form-control" name="password" placeholder="Digite a sua senha">
            </div>
            <button type="submit" class="btn btn-primary">Criar Conta</button>
          </form>
        </div>

        <div class="col-lg">
          <h4>Logue na sua conta</h4>

          <p>
            Se você já tem uma conta, faça login abaixo:
          </p>

          <form action="/login/login" method="GET">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <div class="form-group">
              <label for="exampleInputEmail1">Seu e-mail</label>
              <input type="email" class="form-control" name="email" aria-describedby="emailHelp" placeholder="Digite o seu e-mail">
            </div>
            <div class="form-group">
              <label for="exampleInputPassword1">Password</label>
              <input type="password" class="form-control" name="password" placeholder="Digite a sua senha">
            </div>
            <button type="submit" class="btn btn-primary">Entrar</button>
          </form>
        </div>
      </div>
    <div class="col-lg-2"></div>
  </div>
</div>

<%- include('includes/footer') %>